# ============================================
#               GCS Configuration
# ============================================

PROJECT_ID="<project_id>"
OUTBOUND_BUCKET="<outbound_bucket>"
# GCS Authentication - Choose ONE option:
# ----------------------------------------

# Option 1: Service Account Key (traditional) / Option 2: Workload Identity Pool (WIP) credentials
# GOOGLE_APPLICATION_CREDENTIALS="<path_to_service_account_key / path_to_wip_config_json>"

# Service Account to impersonate (used with WIP)
TARGET_PRINCIPAL="<sa_email_principal>"
TARGET_SCOPES="<target_scopes>"
# For WIP setup instructions, see: WIP_CREDENTIALS_SETUP.md

OIDC_TOKEN_ENDPOINT="<oidc_token_endpoint>"
OIDC_CLIENT_ID="<oidc_client_id>"
OIDC_CLIENT_SECRET="<oidc_client_secret>"

# ============================================
#               HTTP Proxy Configuration
# ============================================

# Proxy Configuration (if behind corporate proxy)
# HTTP_PROXY="<http_proxy>"
# HTTPS_PROXY="<https_proxy>"

# ============================================
#                  DuckDB Tuning
# ============================================
# Maximum RAM DuckDB may allocate before spilling to disk.
# Overrides the constructor default (6GB). Examples: 4GB, 8GB, 12GB
# DUCKDB_MEMORY_LIMIT="6GB"

# Whether DuckDB tracks row insertion order (true/false).
# false reduces peak memory for large analytical workloads.
# DUCKDB_PRESERVE_INSERTION_ORDER="false"

# How aggressively the C allocator returns freed pages to the OS.
# Increase (e.g. 512MB) on systems with ample RAM.
# DUCKDB_ALLOCATOR_FLUSH_THRESHOLD="256MB"

