# ========== SERVER SETTINGS ==========
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
SERVER_ENVIRONMENT=dev
SERVER_DEBUG=true
SERVER_LOG_LEVEL=INFO

# ========== DATABASE SETTINGS ==========
# SQLite (dev - default):
DB_DATABASE_URL=sqlite+aiosqlite:///./file_validator.db

# PostgreSQL (prod - uncomment to use):
# DB_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/file_validator
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ========== CACHE SETTINGS ==========
CACHE_TTL_SECONDS=43200
CACHE_CLEANUP_INTERVAL=3600
CACHE_MAX_CACHE_SIZE_MB=5000

# ========== DUCKDB SETTINGS ==========
DUCKDB_MEMORY_LIMIT=6GB
DUCKDB_THREADS=4
DUCKDB_PRESERVE_INSERTION_ORDER=false
DUCKDB_ALLOCATOR_FLUSH_THRESHOLD=256MB

# ========== FILE UPLOAD SETTINGS ==========
MAX_UPLOAD_SIZE_MB=5000

# ========== GCS SETTINGS ==========
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

